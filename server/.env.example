PORT=3000
NODE_ENV=development

# PostgreSQL superuser or app user — never commit real credentials
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/miqorai?schema=public
REDIS_URL=redis://localhost:6379

JWT_SECRET=generate-a-random-string-at-least-32-chars
JWT_REFRESH_SECRET=generate-another-random-string-at-least-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

ENCRYPTION_KEY=generate-a-32-byte-encryption-key!!
FILE_SIGNING_SECRET=generate-a-file-signing-secret!!

QR_SECRET=generate-a-qr-secret-key
QR_REFRESH_SECONDS=60

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@miqorai.com

SMS_PROVIDER=log
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
SMS_FROM_NUMBER=

CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:8081,http://localhost:8082,http://localhost:8083
UPLOAD_DIR=./uploads
INVITATION_EXPIRY_DAYS=7
RATE_LIMIT_PER_MINUTE=100
AUDIT_ARCHIVE_DAYS=365
OTP_EXPIRES_MINUTES=10
BASE_URL=http://localhost:3000
